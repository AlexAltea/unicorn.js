{
  "name": "@alexaltea/unicorn-js",
  "version": "2.1.4",
  "description": "Unicorn CPU emulator framework port for JavaScript",
  "author": "Alexandro Sanchez Bach <alexaltea123@gmail.com>",
  "license": "GPL-2.0",
  "homepage": "https://alexaltea.github.io/unicorn.js/",
  "keywords": [
    "unicorn",
    "emulator",
    "emulation",
    "cpu",
    "wasm",
    "webassembly",
    "reverse-engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexAltea/unicorn.js.git"
  },
  "main": "./dist/unicorn.js",
  "exports": {
    ".": "./dist/unicorn.js",
    "./arm": "./dist/unicorn_arm.js",
    "./aarch64": "./dist/unicorn_aarch64.js",
    "./arm64": "./dist/unicorn_aarch64.js",
    "./m68k": "./dist/unicorn_m68k.js",
    "./mips": "./dist/unicorn_mips.js",
    "./ppc": "./dist/unicorn_ppc.js",
    "./riscv": "./dist/unicorn_riscv.js",
    "./s390x": "./dist/unicorn_s390x.js",
    "./sparc": "./dist/unicorn_sparc.js",
    "./tricore": "./dist/unicorn_tricore.js",
    "./x86": "./dist/unicorn_x86.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "python3 build.py",
    "build:release": "python3 build.py --release",
    "prepack": "npm run build:release",
    "serve": "python3 -m http.server",
    "test": "node tests/main.js"
  },
  "bugs": {
    "url": "https://github.com/AlexAltea/unicorn.js/issues"
  }
}
