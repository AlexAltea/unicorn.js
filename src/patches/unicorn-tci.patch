--- a/qemu/util/oslib-posix.c
+++ b/qemu/util/oslib-posix.c
@@ -29,7 +29,7 @@
 #include <uc_priv.h>
 #include "qemu/osdep.h"
 
-#ifdef CONFIG_LINUX
+#if defined(CONFIG_LINUX) && !defined(__EMSCRIPTEN__)
 #include <linux/mman.h>
 #else  /* !CONFIG_LINUX */
 #define MAP_SYNC              0x0
@@ -108,7 +108,12 @@
 /* alloc shared memory pages */
 void *qemu_anon_ram_alloc(struct uc_struct *uc, size_t size, uint64_t *alignment)
 {
-#ifdef __MINGW32__
+#ifdef __EMSCRIPTEN__
+    size_t align = QEMU_VMALLOC_ALIGN;
+    void *ptr = qemu_try_memalign(align, size);
+    if (alignment) { *alignment = align; }
+    return ptr;
+#elif defined(__MINGW32__)
     void *ptr;
 
     ptr = VirtualAlloc(NULL, size, MEM_COMMIT, PAGE_READWRITE);
@@ -149,7 +154,9 @@
 
 void qemu_anon_ram_free(struct uc_struct *uc, void *ptr, size_t size)
 {
-#ifdef __MINGW32__
+#ifdef __EMSCRIPTEN__
+    qemu_vfree(ptr);
+#elif defined(__MINGW32__)
     if (ptr) {
         VirtualFree(ptr, 0, MEM_RELEASE);
     }
